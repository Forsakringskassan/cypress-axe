{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": ["cypress", "node"],
        "allowJs": true,
        "checkJs": false,
        "rootDir": ".",
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./dist",
        "declarationDir": "./temp/types",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "paths": {
            "@forsakringskassan/cypress-axe/plugins": ["./src/plugins.js"],
            "@forsakringskassan/cypress-axe/support": ["./src/support.js"]
        }
    },
    "include": [
        "src/**/*.js",
        "src/**/*.ts",
        "vitest.config.ts",
        "vitest.global.ts",
        "cypress.config.ts"
    ]
}
